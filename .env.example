# SQL Server (Microsoft) – used when DB_NAME is set.
# Copy to .env and fill in your values. Leave DB_NAME unset to use SQLite.

DB_NAME=art_gallery
DB_USER=your_sql_server_username
DB_PASSWORD=your_sql_server_password
DB_HOST=127.0.0.1
DB_PORT=1433
# Optional: ODBC driver (default: ODBC Driver 17 for SQL Server)
# DB_DRIVER=ODBC Driver 17 for SQL Server
